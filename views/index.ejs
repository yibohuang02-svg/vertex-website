    <!-- PROCESS -->
    <section class="section process" id="process">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Repair Workflow</div>
          <h2 class="section-title">Rigorous <span class="gradient-text">Step-by-Step</span> Process</h2>
          <p class="section-sub">Every repair follows a documented closed-loop protocol: inspection → diagnosis → repair → validation → delivery.</p>
        </div>
        <div class="process-track">
          <div class="process-line"></div>
          <div class="process-steps">
            <div class="process-step">
              <div class="step-node">01</div>
              <div class="step-content">
                <h4>Unboxing & Registration</h4>
                <p>Unboxing video recorded. Initial customer service contact within 1 hour. Fault description and work order opened.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-node">02</div>
              <div class="step-content">
                <h4>Visual & Electrical Inspection</h4>
                <p>Visual check for impact damage, short-circuit testing, supply voltage and waveform measurement (±5% threshold).</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-node">03</div>
              <div class="step-content">
                <h4>3D Imaging & Fault Localisation</h4>
                <p>X-ray and thermal imaging to pinpoint concealed defects — cold solder joints, oxidation, micro-cracks — accurate Fault Diagnosis Report within 2 hours.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-node">04</div>
              <div class="step-content">
                <h4>Quotation & Approval</h4>
                <p>Itemised repair quotation issued. Customer confirmation required before work commences.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-node">05</div>
              <div class="step-content">
                <h4>Component Repair / Replacement</h4>
                <p>BGA reballing, capacitor replacement, PCB jumper repair, or module swap — all using manufacturer-certified components with second-pass QC.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-node">06</div>
              <div class="step-content">
                <h4>GPU Burn Test & Stress Validation</h4>
                <p>12-hour minimum burn-in under full load. DCGM monitoring, CUDA benchmarks, temperature and power-consumption verification.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-node">07</div>
              <div class="step-content">
                <h4>Final Testing & Report</h4>
                <p>OEM-level platform validation confirms compute performance at ≥98% of factory standard. Full Maintenance Test Report issued.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-node">08</div>
              <div class="step-content">
                <h4>Anti-Static Packaging & Dispatch</h4>
                <p>Triple-layer shockproof packaging with temperature/humidity loggers. Full-process logistics tracking to customer site.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="emergency-block">
          <div class="emergency-header">
            <div class="emergency-dot"></div>
            <h3>Emergency Response Protocol</h3>
            <span class="tag-pill">30-Minute Solution Target</span>
